# .env.example
# Copy this to .env and fill in real values.
# THIS FILE IS COMMITTED — never put real secrets here.
# .env is gitignored and must never be committed.
#
# All variables marked REQUIRED will cause docker-compose to refuse to start if missing.
# Variables with a default (:-) are optional — the shown value is used if unset.

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── Database ──────────────────────────────────────────────────────────────────
# Neon / Supabase / any PostgreSQL.
# DATABASE_URL     → pooled connection (pgBouncer / Neon pooler) — used at runtime
# DIRECT_DATABASE_URL → direct (non-pooled) — used by Prisma migrations only
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<db>?sslmode=require
DIRECT_DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<db>?sslmode=require

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
# REST client — used by RedisService for caching and OTP storage
UPSTASH_REDIS_REST_URL=https://<name>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your-upstash-rest-token>

# ioredis / TLS — used by BullMQ workers (must be rediss:// for Upstash)
UPSTASH_REDIS_IOREDIS_URL=rediss://default:<token>@<name>.upstash.io:6379

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Use separate secrets per service — NEVER share across player/owner/admin.
PLAYER_JWT_SECRET=change-me-min-32-chars
OWNER_JWT_SECRET=change-me-min-32-chars
ADMIN_JWT_SECRET=change-me-min-64-chars-for-admin

# ── Payments ──────────────────────────────────────────────────────────────────
KHALTI_SECRET_KEY=
ESEWA_SECRET_KEY=
ESEWA_PRODUCT_CODE=EPAYTEST
ESEWA_MERCHANT_CODE=
ESEWA_MERCHANT_SECRET=

# ── Storage (S3-compatible: Cloudflare R2, MinIO, AWS S3) ─────────────────────
# STORAGE_PROVIDER=s3 is the only supported value currently.
STORAGE_PROVIDER=s3

# Cloudflare R2:  https://<account-id>.r2.cloudflarestorage.com
# AWS S3:         https://s3.<region>.amazonaws.com
# Local MinIO:    http://localhost:9000
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY=<r2-or-s3-access-key>
S3_SECRET_KEY=<r2-or-s3-secret-key>
S3_BUCKET=<bucket-name>

# true for MinIO / path-style S3 endpoints; false for AWS/R2 virtual-hosted style
S3_FORCE_PATH_STYLE=false

# Optional CDN base URL for public asset URLs (e.g. Cloudflare R2 public domain).
# If empty, S3_ENDPOINT is used to construct asset URLs.
S3_CDN_BASE_URL=https://pub-<hash>.r2.dev

# false = public CDN URLs (fast). true = short-lived signed URLs (private bucket).
USE_SIGNED_IMAGE_URLS=false

# ── Notifications ─────────────────────────────────────────────────────────────
# Firebase service account JSON — paste raw JSON or base64-encoded string.
# Leave empty to disable FCM push notifications.
FIREBASE_SERVICE_ACCOUNT=

SPARROW_SMS_TOKEN=
RESEND_API_KEY=re_<your-resend-api-key>

# ── OTP Configuration ─────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_LENGTH=6

# ── Admin Security ────────────────────────────────────────────────────────────
# Comma-separated list of IPs/CIDRs allowed to call /api/v1/admin/*
# Docker internal subnet (172.20.0.0/16) must always be included for healthchecks.
# Add your office/VPN IP before going to production.
ADMIN_ALLOWED_IPS=127.0.0.1,172.20.0.0/16

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=https://futsmandu.app

# ── Service Ports (override if you have conflicts) ────────────────────────────
PLAYER_API_PORT=3001
OWNER_API_PORT=3002
ADMIN_API_PORT=3003

# ── Database Pool Sizes ───────────────────────────────────────────────────────
DB_POOL_SIZE=5
OWNER_DB_POOL_SIZE=5
ADMIN_DB_POOL_SIZE=3
WORKER_DB_POOL_SIZE=2

# ── Observability (Sentry) ────────────────────────────────────────────────────
# Leave SENTRY_DSN empty to disable Sentry error tracking.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=1.0.0
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Admin Seed (one-time) ─────────────────────────────────────────────────────
# Used by: pnpm seed:admin
# Only needed on first setup. Do not expose to frontend devs.
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=change-me-strong-password
ADMIN_SEED_ROLE=ADMIN
ADMIN_SEED_NAME=Seed Admin
