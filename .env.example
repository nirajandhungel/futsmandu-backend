# .env.example
# Copy this to .env and fill in real values.
# THIS FILE IS COMMITTED — never put real secrets here.
# .env is gitignored and must never be committed.
#
# All variables without a default here are REQUIRED.
# docker-compose.yml will fail to start if they are missing.

# ── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── Database (Supabase) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres?pgbouncer=true
DIRECT_DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
# Upstash production/dev (unified Redis instance):
#   UPSTASH_REDIS_IOREDIS_URL=rediss://<user>:<token>@<host>:6380
UPSTASH_REDIS_IOREDIS_URL=

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
PLAYER_JWT_SECRET=change-me-before-use
OWNER_JWT_SECRET=change-me-before-use
ADMIN_JWT_SECRET=change-me-before-use

# ── Payments ──────────────────────────────────────────────────────────────────
KHALTI_SECRET_KEY=
ESEWA_SECRET_KEY=
ESEWA_PRODUCT_CODE=

# ── Storage (Provider-agnostic S3) ────────────────────────────────────────────
# Local dev (MinIO):  STORAGE_PROVIDER=s3 + S3_ENDPOINT=http://localhost:9000
# Production (R2):    STORAGE_PROVIDER=s3 + S3_ENDPOINT=https://<id>.r2.cloudflarestorage.com
STORAGE_PROVIDER=s3
S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_FORCE_PATH_STYLE=false
# Optional: set a CDN/public base URL (e.g. Cloudflare R2 custom domain).
# If unset, S3_ENDPOINT is used to construct public asset URLs.
S3_CDN_BASE_URL=

# ── Notifications ─────────────────────────────────────────────────────────────
SPARROW_SMS_TOKEN=
# Firebase service account JSON (base64-encoded or raw JSON string)
FIREBASE_SERVICE_ACCOUNT=
RESEND_API_KEY=

# ── Admin ─────────────────────────────────────────────────────────────────────
# Comma-separated IPs allowed to call /api/v1/admin/*
# Must match the allow directives in nginx/sites-available/futsmandu-routes.conf
ADMIN_ALLOWED_IPS=127.0.0.1,172.20.0.0/16

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=https://futsmandu.app

# ── Database pool sizes ───────────────────────────────────────────────────────
DB_POOL_SIZE=5
OWNER_DB_POOL_SIZE=5
ADMIN_DB_POOL_SIZE=3
WORKER_DB_POOL_SIZE=2

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=
