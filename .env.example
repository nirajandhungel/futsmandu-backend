# .env.example
# Copy this to .env and fill in real values.
# THIS FILE IS COMMITTED — never put real secrets here.
# .env is gitignored and must never be committed.
#
# All variables without a default here are REQUIRED.
# docker-compose.yml will fail to start if they are missing.

# ── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── Database (Supabase) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres?pgbouncer=true
DIRECT_DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local Docker Redis (used by docker-compose redis service):
#   REDIS_PASSWORD must match --requirepass in docker-compose.yml redis command.
#   REDIS_URL inside Docker network: redis://:<password>@redis:6379
#   REDIS_URL from host machine (local dev): redis://:<password>@localhost:6379
#
# Upstash production (replaces the local redis service entirely):
#   REDIS_URL=rediss://<user>:<token>@<host>:6380
REDIS_PASSWORD=change-me-before-use
REDIS_URL=redis://:change-me-before-use@redis:6379

# Upstash REST (used by @futsmandu/redis for HTTP-based caching — optional)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Upstash ioredis-compatible URL (set this if you use Upstash for BullMQ too)
UPSTASH_REDIS_IOREDIS_URL=

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
PLAYER_JWT_SECRET=change-me-before-use
OWNER_JWT_SECRET=change-me-before-use
ADMIN_JWT_SECRET=change-me-before-use

# ── Payments ──────────────────────────────────────────────────────────────────
KHALTI_SECRET_KEY=
ESEWA_SECRET_KEY=
ESEWA_PRODUCT_CODE=

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
CF_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_CDN_BASE_URL=

# ── Notifications ─────────────────────────────────────────────────────────────
SPARROW_SMS_TOKEN=
# Firebase service account JSON (base64-encoded or raw JSON string)
FIREBASE_SERVICE_ACCOUNT=
RESEND_API_KEY=

# ── Admin ─────────────────────────────────────────────────────────────────────
# Comma-separated IPs allowed to call /api/v1/admin/*
# Must match the allow directives in nginx/sites-available/futsmandu-routes.conf
ADMIN_ALLOWED_IPS=127.0.0.1,172.20.0.0/16

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=https://futsmandu.app

# ── Database pool sizes ───────────────────────────────────────────────────────
DB_POOL_SIZE=5
OWNER_DB_POOL_SIZE=5
ADMIN_DB_POOL_SIZE=3
WORKER_DB_POOL_SIZE=2

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=
