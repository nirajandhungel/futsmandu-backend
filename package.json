{
  "name": "futsmandu-server",
  "version": "2.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "description": "Futsmandu monorepo — Player API + Owner API + Admin API (three independent NestJS + Fastify servers)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "overrides": {
      "ajv": "^8.18.0",
      "@tootallnate/once": "^3.0.1",
      "effect": "^3.20.0",
      "path-to-regexp": "^8.4.0",
      "picomatch": "^4.0.4"
    },
    "ignoredBuiltDependencies": [
      "@nestjs/core",
      "@scarf/scarf",
      "@sentry-internal/node-cpu-profiler",
      "msgpackr-extract"
    ],
    "onlyBuiltDependencies": [
      "@firebase/util",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "protobufjs",
      "sharp"
    ]
  },
  "scripts": {
    "clean": "echo '🧹 Deep cleaning project...' && find . -type d \\( -name 'node_modules' -o -name 'dist' -o -name '.turbo' -o -path '*/packages/database/generated' \\) -not -path './.git/*' -exec rm -rf {} + 2>/dev/null || true && find . \\( -name '*.tsbuildinfo' -o -name '*.log' -o -name '.env.local' \\) -not -path './.git/*' -delete 2>/dev/null || true && echo '✅ Cleaned all node_modules, dist, .turbo, generated, tsbuildinfo, logs, and temp files'",
    "clean:deep": "pnpm run clean && echo '💣 Removing lockfile...' && npx -y rimraf pnpm-lock.yaml && echo '✅ Deep clean complete — run pnpm install'",
    "setup": "echo '🚀 Setting up project...' && echo '📦 Installing dependencies...' && pnpm install --frozen-lockfile && echo '📝 Validating environment...' && node scripts/validate-env.mjs && echo '🔄 Generating Prisma client...' && pnpm prisma:generate && echo '🛠️ Building packages...' && pnpm run build:packages && echo '💾 Syncing database schema...' && pnpm prisma:push && echo '🏗️ Building apps...' && pnpm run build:apps && echo '✨ Setup complete! Run pnpm dev:all to start development servers'",
    "reset": "pnpm run clean:deep && pnpm run setup",
    "bootstrap": "pnpm docker:up && pnpm run setup",
    "build": "pnpm build:packages && pnpm build:apps",
    "build:packages": "pnpm --filter \"./packages/**\" run build",
    "build:apps": "pnpm --filter \"./apps/**\" run build",
    "db:reset": "pnpm --filter @futsmandu/database exec dotenv -e ../../.env -- prisma migrate reset",
    "prisma:generate": "pnpm --filter @futsmandu/database prisma:generate",
    "prisma:migrate:dev": "pnpm --filter @futsmandu/database prisma:migrate:dev",
    "prisma:migrate:deploy": "pnpm --filter @futsmandu/database prisma:migrate:deploy",
    "prisma:push": "pnpm --filter @futsmandu/database prisma:push",
    "prisma:studio": "pnpm --filter @futsmandu/database prisma:studio",
    "prisma:dev": "pnpm --filter @futsmandu/database exec prisma migrate dev",
    "prisma:deploy": "pnpm --filter @futsmandu/database exec prisma migrate deploy",
    "prisma:reset": "pnpm --filter @futsmandu/database exec prisma migrate reset",
    "prisma:status": "pnpm --filter @futsmandu/database exec prisma migrate status",
    "prisma:pull": "pnpm --filter @futsmandu/database exec prisma db pull",
    "prisma:format": "pnpm --filter @futsmandu/database exec prisma format",
    "dev": "pnpm dev:player",
    "dev:all": "pnpm start:all",
    "dev:player": "pnpm --filter @futsmandu/player-api dev",
    "dev:owner": "pnpm --filter @futsmandu/owner-api dev",
    "dev:admin": "pnpm --filter @futsmandu/admin-api dev",
    "dev:worker:player": "pnpm --filter @futsmandu/player-api dev:worker",
    "dev:worker:owner": "pnpm --filter @futsmandu/owner-api dev:worker",
    "dev:worker:admin": "pnpm --filter @futsmandu/admin-api dev:worker",
    "start:dev": "concurrently -n PLAYER,OWNER,ADMIN -c green,yellow,blue \"pnpm dev:player\" \"pnpm dev:owner\" \"pnpm dev:admin\"",
    "start:worker": "concurrently -n PLAYER-W,OWNER-W,ADMIN-W -c green,yellow,blue \"pnpm dev:worker:player\" \"pnpm dev:worker:owner\" \"pnpm dev:worker:admin\"",
    "start:all": "concurrently --kill-others-on-fail -n API,WORKER -c cyan,magenta \"pnpm start:dev\" \"pnpm start:worker\"",
    "start": "concurrently \"pnpm --filter @futsmandu/player-api start\" \"pnpm --filter @futsmandu/owner-api start\" \"pnpm --filter @futsmandu/admin-api start\"",
    "deploy": "pnpm run setup && pnpm start",
    "test": "jest --passWithNoTests",
    "lint": "eslint 'apps/**/*.ts' 'packages/**/*.ts'",
    "docker:build": "docker compose --env-file .env -f infrastructure/docker-compose.yml build",
    "docker:up": "docker compose --env-file .env -f infrastructure/docker-compose.yml up -d",
    "docker:down": "docker compose --env-file .env -f infrastructure/docker-compose.yml down",
    "docker:logs": "docker compose --env-file .env -f infrastructure/docker-compose.yml logs -f",
    "docker:ps": "docker compose --env-file .env -f infrastructure/docker-compose.yml ps",
    "docker:restart": "docker compose --env-file .env -f infrastructure/docker-compose.yml restart",

    "hub:tag": "node scripts/docker-tag.mjs",
    "hub:push": "node scripts/docker-tag.mjs && node scripts/docker-push.mjs",
    "hub:publish": "pnpm docker:build && pnpm hub:push",

    "hub:up": "docker compose --env-file .env -f infrastructure/docker-compose.hub.yml up -d",
    "hub:down": "docker compose --env-file .env -f infrastructure/docker-compose.hub.yml down",
    "hub:pull": "docker compose --env-file .env -f infrastructure/docker-compose.hub.yml pull",

    "seed:admin": "pnpm --filter @futsmandu/admin-api exec dotenv -e ../../.env -- tsx src/scripts/seed-admin.ts",
    "seed:config": "pnpm --filter @futsmandu/admin-api exec dotenv -e ../../.env -- tsx src/scripts/seed-config.ts"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "dotenv-safe": "^9.1.0",
    "eslint": "^9.25.1",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@fastify/static": "^9.0.0"
  }
}