# infrastructure/nginx/proxy_params
# Shared proxy settings — included in every proxy_pass location block.
# Keeping this in a separate file prevents duplication across route definitions.

proxy_http_version     1.1;
proxy_set_header       Host               $host;
proxy_set_header       X-Real-IP          $remote_addr;
proxy_set_header       X-Forwarded-For    $proxy_add_x_forwarded_for;
proxy_set_header       X-Forwarded-Proto  $scheme;
# Use $connection.$msec as a request-scoped ID (nginx OSS — no $request_id available).
# This is set as both a proxy header (for upstream logging) and a response header
# (in futsmandu-routes.conf) so the client can correlate errors with server logs.
proxy_set_header       X-Request-ID       $connection.$msec;
# Clear Connection header — required for HTTP/1.1 keepalive to upstreams.
proxy_set_header       Connection         "";

proxy_connect_timeout  10s;
proxy_send_timeout     30s;
proxy_read_timeout     30s;

proxy_buffering        on;
proxy_buffer_size      4k;
proxy_buffers          8 4k;

# No retry on upstream error for POST requests — booking holds and payments
# are not idempotent. A single failed attempt must surface to the client.
proxy_next_upstream       error timeout;
proxy_next_upstream_tries 1;
