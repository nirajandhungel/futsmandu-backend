    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^9.0.0",
    "@futsmandu/auth": "workspace:*",
    "@futsmandu/database": "workspace:*",
    "@futsmandu/logger": "workspace:*",
    "@futsmandu/media": "workspace:*",
    "@futsmandu/media-core": "workspace:*",
    "@futsmandu/queues": "workspace:*",
    "@futsmandu/redis": "workspace:*",
    "@futsmandu/types": "workspace:*",
    "@futsmandu/utils": "workspace:*",
